"""Local user settings for idownscale.

Copy this file to ``iriscc/settings_local.py`` and adapt the paths for your
machine/account. The real ``settings_local.py`` file is ignored by Git.

Environment variables still take precedence, which is useful for one-off runs
or Slurm jobs.
"""

from pathlib import Path

SCRATCH_ROOT = Path("/scratch/globc/<user>")
RUNTIME_ROOT = SCRATCH_ROOT / "idownscale_runtime"
OUTPUT_ROOT = RUNTIME_ROOT / "output"
GRAPHS_ROOT = RUNTIME_ROOT / "graphs"
RAWDATA_ROOT = SCRATCH_ROOT / "idownscale_rawdata"

PATHS = {
    "IDOWNSCALE_RUNTIME_ROOT": RUNTIME_ROOT,
    "IDOWNSCALE_RAW_DIR": RAWDATA_ROOT,
    "IDOWNSCALE_OUTPUT_DIR": OUTPUT_ROOT,
    "IDOWNSCALE_GRAPHS_DIR": GRAPHS_ROOT,
    "IDOWNSCALE_DATASET_DIR": OUTPUT_ROOT / "datasets",
    "IDOWNSCALE_DATASET_BC_DIR": OUTPUT_ROOT / "datasets" / "dataset_bc",
    "IDOWNSCALE_RUNS_DIR": OUTPUT_ROOT / "runs",
    "IDOWNSCALE_PREDICTION_DIR": OUTPUT_ROOT / "prediction",
    "IDOWNSCALE_METRICS_DIR": OUTPUT_ROOT / "metrics",
    "IDOWNSCALE_REGRID_WEIGHTS_DIR": OUTPUT_ROOT / "regrid_weights",
    "IDOWNSCALE_GCM_BC_DIR": RAWDATA_ROOT / "gcm" / "CNRM-CM6-1-BC",
    "IDOWNSCALE_RCM_BC_DIR": RAWDATA_ROOT / "rcm" / "ALADIN-BC",
    "IDOWNSCALE_CORDEX_BC_DIR": RAWDATA_ROOT / "rcm" / "CORDEX-BC",
    "IDOWNSCALE_EXP5_ARCHIVE_DATASET_DIR": OUTPUT_ROOT / "datasets" / "dataset_exp5_30y",
}
